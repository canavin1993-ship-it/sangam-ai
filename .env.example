# ===========================================
# SUPABASE - Database & Auth
# ===========================================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key
VITE_SUPABASE_URL=https://your-project.supabase.co
VITE_SUPABASE_ANON_KEY=your-anon-key

# ===========================================
# RAZORPAY - Payment Processing
# ===========================================
RAZORPAY_KEY_ID=rzp_test_xxxxx
RAZORPAY_KEY_SECRET=xxxxxxxxxxxxxxxxxx
RAZORPAY_WEBHOOK_SECRET=xxxxxxxxxxxxxxxxxx

# ===========================================
# LOVABLE AI - Gemini AI for Matching
# ===========================================
LOVABLE_API_KEY=lovable_api_key_here

# ===========================================
# FIREBASE - Phone OTP Authentication
# Get from Firebase Console > Project Settings
# ===========================================
VITE_FIREBASE_API_KEY=AIzaSyxxxxxxxxxxxxxxxxxxxxxxx
VITE_FIREBASE_AUTH_DOMAIN=your-project.firebaseapp.com
VITE_FIREBASE_PROJECT_ID=your-project-id

# Server-side Firebase Admin (JSON string or path to service account)
FIREBASE_ADMIN_SDK={"type":"service_account","project_id":"..."}

# ===========================================
# MSG91 - SMS OTP Backup (Optional)
# ===========================================
MSG91_AUTH_KEY=YourMsg91AuthKey

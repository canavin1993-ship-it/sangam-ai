  "installCommand": "npm install",
  "devCommand": "npm run dev",
  "regions": [
    "bom1"
  ],
  "name": "sangam-ai-app",
  "env": {
    "VITE_SUPABASE_URL": "https://qaepqgewsduhftsjvjew.supabase.co",
    "VITE_SUPABASE_PROJECT_ID": "qaepqgewsduhftsjvjew",
    "VITE_SUPABASE_PUBLISHABLE_KEY": "sb_publishable_SPH_sdqDiTfugygyEY3Hag_Tv9X1loM"
  },
  "headers": [
    {
      "source": "/(.*)",
